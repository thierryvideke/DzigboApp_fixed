<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- Fond décoratif -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/splash_glow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="60dp" />

    <!-- Emoji logo -->
    <TextView
        android:id="@+id/splash_emoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🛒"
        android:textSize="72sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/splash_title"
        android:layout_marginBottom="16dp" />

    <!-- Titre -->
    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chez Dzigbo"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#C9A84C"
        android:fontFamily="serif"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Sous-titre -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lomé · Togo 🇹🇬"
        android:textSize="14sp"
        android:textColor="#8A8A9A"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@+id/splash_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Loading dots -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="· · ·"
        android:textSize="20sp"
        android:textColor="#C9A84C"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="60dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
